{
    "version": "0.2",
    "language": "en",
    "dictionaries": [
        "custom",
        "softwareTerms",
        "finance"
    ],
    "dictionaryDefinitions": [
        {
            "name": "custom",
            "path": "./.vscode/project-terms.txt",
            "addWords": true
        }
    ],
    "ignorePaths": [
        "node_modules",
        "dist",
        "*.pyc",
        "*.ipynb",
        ".git",
        ".venv"
    ],
    "words": [
        "MonteCarlo",
        "withdrawalStrategy",
        "retirementBlueprint",
        "simulatorConfig",
        "cspell",
        "workstream",
        "pyproject",
        "jsonschema"
    ],
    "enableFiletypes": [
        ".js",
        ".ts",
        ".py",
        ".md",
        ".json"
    ]
}